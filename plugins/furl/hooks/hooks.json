{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash|WebFetch|WebSearch|Task",
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'uv run --no-project --with \"furl-ctx[mcp]==1.0.2\" python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/compress_tool_output.py\" || true'",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ \"$FURL_STATUS_LINE\" = \"0\" ] || printf \"%s\" \"{\\\"systemMessage\\\": \\\"furl 1.0.5 active — PostToolUse compression armed; store: per-project (~/.furl); verify: furl_stats\\\"}\"; true'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
